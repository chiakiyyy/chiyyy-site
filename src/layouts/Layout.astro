---
const { title = "chiyyy.com" } = Astro.props;
---

<!doctype html>
<html lang="ja">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width" />
	<link rel="icon" href="/favicon.ico" />
	<title>{title}</title>
</head>

<body>

<header>
	<h1>
		<a href="/">chiyyy.com</a>
	</h1>

	<nav>
		<a href="/">Home</a>
		<a href="/about">About</a>
	</nav>
</header>

<main>
	<slot />
</main>

</body>
</html>

<style>
:root{
	--text:#222;
	--border:#eee;
}

body{
	max-width:1100px;
	margin:0 auto;
	padding:40px 20px;
	color:var(--text);
	font-family:
		-apple-system,
		BlinkMacSystemFont,
		"Helvetica Neue",
		sans-serif;
	line-height:1.8;
}

header{
	display:flex;
	justify-content:space-between;
	align-items:center;
	margin-bottom:60px;
}

h1{
	margin:0;
	font-size:2rem;
}

a{
	color:inherit;
	text-decoration:none;
}

nav{
	display:flex;
	gap:20px;
}
</style>