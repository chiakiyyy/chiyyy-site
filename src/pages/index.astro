---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const posts = allPosts.sort((a, b) =>
  new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
const featuredPosts = posts.slice(0, 2);
const latestPosts = posts.slice(2);
---

<Layout title="chiyyy.com" description="日常・ライフスタイル・旅・AIのブログ">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-img-wrap">
      <img src="/images/hero.svg" alt="" class="hero-img" />
    </div>
    <div class="hero-ticker">
      <div class="ticker-inner">
        {posts.map(p => (
          <a href={`/blog/${p.id.replace(/\.md$/, '')}/`} class="ticker-item">
            <span class="ticker-cat">{p.data.category}</span>
            <span class="ticker-title">{p.data.title}</span>
          </a>
        ))}
        {posts.map(p => (
          <a href={`/blog/${p.id.replace(/\.md$/, '')}/`} class="ticker-item" aria-hidden="true">
            <span class="ticker-cat">{p.data.category}</span>
            <span class="ticker-title">{p.data.title}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- NEW POSTS -->
  <section class="section">
    <div class="section-inner">
      <div class="section-head">
        <span class="section-label">NEW POST</span>
      </div>
      <div class="featured-grid">
        {featuredPosts.map((post) => {
          const slug = post.id.replace(/\.md$/, '');
          const dateStr = post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' });
          return (
            <article class="featured-card">
              <a href={`/blog/${slug}/`} class="featured-card-link">
                <div class="featured-thumb">
                  {post.data.thumbnail
                    ? <img src={post.data.thumbnail} alt={post.data.title} loading="lazy" />
                    : <div class="thumb-blank"><span>{post.data.category}</span></div>
                  }
                </div>
                <div class="featured-body">
                  <p class="card-cat">{post.data.category}</p>
                  <h2 class="card-title">{post.data.title}</h2>
                  <p class="card-desc">{post.data.description}</p>
                  <time class="card-date">{dateStr}</time>
                </div>
              </a>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- LATEST -->
  {latestPosts.length > 0 && (
    <section class="section">
      <div class="section-inner">
        <div class="section-head">
          <span class="section-label">LATEST</span>
        </div>
        <div class="latest-grid">
          {latestPosts.map((post) => {
            const slug = post.id.replace(/\.md$/, '');
            const dateStr = post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' });
            return (
              <article class="latest-card">
                <a href={`/blog/${slug}/`}>
                  <div class="latest-thumb">
                    {post.data.thumbnail
                      ? <img src={post.data.thumbnail} alt={post.data.title} loading="lazy" />
                      : <div class="thumb-blank"><span>{post.data.category}</span></div>
                    }
                  </div>
                  <p class="card-cat">{post.data.category}</p>
                  <h3 class="latest-title">{post.data.title}</h3>
                  <time class="card-date">{dateStr}</time>
                </a>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )}

</Layout>

<style>
/* ===== HERO ===== */
.hero { background: var(--bg-white); }

.hero-img-wrap {
  width: 100%;
  height: clamp(240px, 40vw, 480px);
  overflow: hidden;
}

.hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero-ticker {
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  overflow: hidden;
  background: var(--bg);
  padding: 10px 0;
}

.ticker-inner {
  display: flex;
  gap: 0;
  white-space: nowrap;
  animation: ticker 30s linear infinite;
  width: max-content;
}

.ticker-item {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 0 32px;
  font-size: 0.7rem;
  color: var(--text-mid);
  letter-spacing: 0.06em;
  border-right: 1px solid var(--border);
  transition: color 0.2s;
}

.ticker-item:hover { color: var(--text); }

.ticker-cat {
  font-size: 0.6rem;
  letter-spacing: 0.14em;
  color: var(--accent);
  font-weight: 500;
}

@keyframes ticker {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ===== SECTION ===== */
.section { padding: 56px 0 0; }

.section-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 32px;
}

.section-head {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 28px;
}

.section-head::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
}

.section-label {
  font-family: var(--font-en);
  font-size: 0.75rem;
  letter-spacing: 0.22em;
  color: var(--text-light);
  font-style: italic;
  white-space: nowrap;
}

/* ===== FEATURED GRID ===== */
.featured-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2px;
  background: var(--border);
  border: 1px solid var(--border);
}

.featured-card { background: var(--bg-white); }

.featured-card-link { display: block; }

.featured-thumb {
  aspect-ratio: 16/10;
  overflow: hidden;
  background: var(--border);
}

.featured-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.featured-card:hover .featured-thumb img { transform: scale(1.04); }

.thumb-blank {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ede9e3;
}

.thumb-blank span {
  font-family: var(--font-en);
  font-style: italic;
  font-size: 1.6rem;
  color: #c4bdb4;
  letter-spacing: 0.1em;
}

.featured-body {
  padding: 20px 24px 28px;
}

/* ===== LATEST GRID ===== */
.latest-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px 24px;
}

.latest-card a { display: block; }

.latest-thumb {
  aspect-ratio: 4/3;
  overflow: hidden;
  background: var(--border);
  margin-bottom: 14px;
}

.latest-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.latest-card:hover .latest-thumb img { transform: scale(1.04); }

.latest-title {
  font-family: var(--font-jp-serif);
  font-size: 0.92rem;
  font-weight: 400;
  line-height: 1.7;
  color: var(--text);
  margin: 6px 0 8px;
}

/* ===== SHARED CARD PARTS ===== */
.card-cat {
  font-size: 0.62rem;
  letter-spacing: 0.18em;
  color: var(--accent);
  font-weight: 500;
  margin-bottom: 6px;
}

.card-title {
  font-family: var(--font-jp-serif);
  font-size: 1.05rem;
  font-weight: 400;
  line-height: 1.7;
  color: var(--text);
  margin-bottom: 10px;
}

.card-desc {
  font-size: 0.8rem;
  color: var(--text-mid);
  line-height: 1.8;
  margin-bottom: 12px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-date {
  font-size: 0.65rem;
  color: var(--text-light);
  letter-spacing: 0.08em;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 768px) {
  .section-inner { padding: 0 20px; }
  .featured-grid { grid-template-columns: 1fr; }
  .latest-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 480px) {
  .latest-grid { grid-template-columns: 1fr; gap: 24px; }
  .section { padding: 40px 0 0; }
}
</style>
