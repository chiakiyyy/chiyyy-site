---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .map(p => ({
    slug: p.id.replace(/\.md$/, ''),
    title: p.data.title,
    description: p.data.description,
    category: p.data.category,
    tags: p.data.tags || [],
    thumbnail: p.data.thumbnail || '',
    date: p.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' }),
  }));
---

<Layout title="検索 | chiyyy.com" description="chiyyy.com の記事を、キーワードやタグで検索できます。">

  <div class="search-wrap">
    <header class="search-header">
      <p class="search-label">SEARCH</p>
      <h1 class="search-title">記事をさがす</h1>
    </header>

    <div class="search-divider"></div>

    <div class="search-box">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <input id="q" type="search" placeholder="キーワードを入力（例：富山、禁煙、移住）" autocomplete="off" />
    </div>

    <p id="count" class="search-count"></p>
    <div id="results" class="search-grid"></div>
    <p id="empty" class="search-empty" hidden>該当する記事が見つかりませんでした。別のキーワードでお試しください。</p>
  </div>

</Layout>

<script is:inline define:vars={{ posts }}>
  const input = document.getElementById('q');
  const results = document.getElementById('results');
  const countEl = document.getElementById('count');
  const emptyEl = document.getElementById('empty');

  const norm = (s) => (s || '').toString().toLowerCase();

  function cardHtml(p) {
    const thumb = p.thumbnail
      ? `<div class="s-thumb"><img src="${p.thumbnail}" alt="${p.title}" loading="lazy" /><span class="s-cat">${p.category}</span></div>`
      : `<div class="s-thumb"><div class="s-blank"><span>${p.category}</span></div><span class="s-cat">${p.category}</span></div>`;
    return `<article class="s-card"><a href="/blog/${p.slug}/">${thumb}<h3 class="s-title">${p.title}</h3><time class="s-date">${p.date}</time></a></article>`;
  }

  function render(list, q) {
    results.innerHTML = list.map(cardHtml).join('');
    if (!q) {
      countEl.textContent = `全 ${list.length} 記事`;
    } else {
      countEl.textContent = `「${q}」の検索結果：${list.length} 件`;
    }
    emptyEl.hidden = list.length !== 0;
  }

  function search(q) {
    const nq = norm(q).trim();
    if (!nq) return posts;
    return posts.filter(p => {
      const hay = norm(p.title) + ' ' + norm(p.description) + ' ' + norm(p.category) + ' ' + norm((p.tags || []).join(' '));
      return nq.split(/\s+/).every(term => hay.includes(term));
    });
  }

  function update() {
    const q = input.value;
    render(search(q), q.trim());
    const url = new URL(window.location.href);
    if (q.trim()) url.searchParams.set('q', q.trim()); else url.searchParams.delete('q');
    history.replaceState(null, '', url);
  }

  // 初期表示：URL の ?q= を反映
  const initial = new URL(window.location.href).searchParams.get('q') || '';
  input.value = initial;
  render(search(initial), initial.trim());

  input.addEventListener('input', update);
</script>

<style>
.search-wrap { max-width: 1100px; margin: 0 auto; padding: 56px 32px 80px; }
.search-header { text-align: center; }
.search-label {
  font-family: var(--font-jp); font-size: 0.72rem; letter-spacing: 0.18em;
  color: var(--accent); font-weight: 500; margin-bottom: 10px;
}
.search-title {
  font-family: var(--font-jp-serif); font-size: clamp(1.4rem, 3vw, 1.8rem);
  font-weight: 400; color: var(--text); letter-spacing: 0.04em;
}
.search-divider { width: 40px; height: 1px; background: var(--accent); margin: 28px auto 40px; }

.search-box {
  display: flex; align-items: center; gap: 12px;
  max-width: 560px; margin: 0 auto 12px;
  border: 1px solid var(--border); background: var(--bg-white);
  padding: 12px 18px; color: var(--text-light);
}
.search-box input {
  flex: 1; border: none; outline: none; background: transparent;
  font-family: var(--font-jp); font-size: 0.9rem; color: var(--text); font-weight: 300;
}

.search-count {
  text-align: center; font-size: 0.72rem; color: var(--text-light);
  letter-spacing: 0.06em; margin: 18px 0 32px;
}

.search-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 36px 24px; }

.s-card a { display: block; }
.s-thumb { position: relative; aspect-ratio: 4/3; overflow: hidden; background: var(--border); margin-bottom: 12px; }
.s-thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
.s-card:hover .s-thumb img { transform: scale(1.04); }
.s-blank { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #ede9e3; }
.s-blank span { font-family: var(--font-en); font-style: italic; font-size: 1.2rem; color: #c4bdb4; }
.s-cat {
  position: absolute; left: 0; bottom: 0; font-size: 0.6rem; letter-spacing: 0.14em;
  background: var(--accent); color: #fff; font-weight: 500; padding: 3px 10px;
}
.s-title {
  font-family: var(--font-jp-serif); font-size: 0.9rem; font-weight: 400;
  line-height: 1.7; color: var(--text); margin: 4px 0 6px;
}
.s-date { font-size: 0.65rem; color: var(--text-light); letter-spacing: 0.08em; }

.search-empty { text-align: center; color: var(--text-mid); font-size: 0.85rem; padding: 40px 0; }

@media (max-width: 768px) {
  .search-wrap { padding: 44px 20px 64px; }
  .search-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .search-grid { grid-template-columns: 1fr; }
}
</style>
