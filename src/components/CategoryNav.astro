---
const { active = '' } = Astro.props;
const categories = [
  { label: 'すべて', slug: '' },
  { label: 'AI', slug: 'ai' },
  { label: '日常', slug: 'life' },
  { label: '旅', slug: 'travel' },
];
---

<nav class="cat-nav">
  {categories.map(c => (
    <a
      href={c.slug ? `/category/${c.slug}` : '/'}
      class={`cat-link ${active === c.slug ? 'active' : ''}`}
    >
      {c.label}
    </a>
  ))}
</nav>

<style>
.cat-nav {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.cat-link {
  padding: 6px 16px;
  border: 1px solid var(--border);
  border-radius: 2px;
  font-size: 0.78rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  color: var(--gray);
  transition: all 0.2s;
}

.cat-link:hover,
.cat-link.active {
  background: var(--black);
  border-color: var(--black);
  color: #fff;
}
</style>
