---
const { post, featured = false } = Astro.props;
const { title, description, pubDate, category, thumbnail } = post.data;

const dateStr = pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric', month: 'long', day: 'numeric'
});

const categoryColors: Record<string, string> = {
  'AI': '#4a7c59',
  '日常': '#7c5c4a',
  '旅': '#4a5d7c',
  '開発': '#6b4a7c',
};
const catColor = categoryColors[category] || '#666';

const slug = post.id.replace(/\.md$/, '');
---

<article class={`post-card ${featured ? 'featured' : ''}`}>
  <a href={`/blog/${slug}/`} class="card-link">
    <div class="card-thumb">
      {thumbnail
        ? <img src={thumbnail} alt={title} loading="lazy" />
        : <div class="thumb-placeholder">
            <span class="thumb-category" style={`color:${catColor}`}>{category}</span>
          </div>
      }
    </div>
    <div class="card-body">
      <span class="card-category" style={`color:${catColor}`}>{category}</span>
      <h2 class="card-title">{title}</h2>
      <p class="card-desc">{description}</p>
      <time class="card-date">{dateStr}</time>
    </div>
  </a>
</article>

<style>
.post-card {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 4px;
  overflow: hidden;
  transition: transform 0.25s, box-shadow 0.25s;
}

.post-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 32px rgba(0,0,0,0.08);
}

.card-link {
  display: block;
  height: 100%;
}

.card-thumb {
  aspect-ratio: 16/10;
  overflow: hidden;
  background: var(--bg-soft);
}

.card-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s;
}

.post-card:hover .card-thumb img {
  transform: scale(1.04);
}

.thumb-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-soft);
}

.thumb-category {
  font-family: var(--font-serif);
  font-size: 1.4rem;
  font-weight: 700;
  opacity: 0.35;
  letter-spacing: 0.1em;
}

.card-body {
  padding: 20px 22px 24px;
}

.card-category {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.card-title {
  font-family: var(--font-serif);
  font-size: 1.05rem;
  font-weight: 700;
  line-height: 1.6;
  margin: 8px 0 10px;
  color: var(--black);
}

.card-desc {
  font-size: 0.82rem;
  color: var(--gray);
  line-height: 1.7;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 14px;
}

.card-date {
  font-size: 0.72rem;
  color: var(--gray-light);
  letter-spacing: 0.04em;
}

/* featured card */
.post-card.featured .card-title {
  font-size: 1.2rem;
}
</style>
