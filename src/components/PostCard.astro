---
const { post } = Astro.props;
---

<article class="card">
	<a href={`/blog/${post.slug}/`}>
		<p class="category">{post.data.category}</p>
		<h2>{post.data.title}</h2>
		<p>{post.data.description}</p>
	</a>
</article>

<style>
.card{
	padding:32px 0;
	border-bottom:1px solid #eee;
}

.category{
	font-size:0.85rem;
	color:#777;
}

h2{
	font-size:1.8rem;
	margin:0 0 12px;
}
</style>